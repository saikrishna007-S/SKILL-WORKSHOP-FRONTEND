4. Simple AuthContext (React)
context/AuthContext.jsx:

jsx
import React, { createContext, useState, useContext, useEffect } from "react";

const AuthContext = createContext();

export function AuthProvider({ children }) {
  const [user, setUser] = useState(null);

  useEffect(() => {
    const saved = localStorage.getItem("authUser");
    if (saved) setUser(JSON.parse(saved));
  }, []);

  const login = (userData) => {
    setUser(userData);
    localStorage.setItem("authUser", JSON.stringify(userData));
  };

  const logout = () => {
    setUser(null);
    localStorage.removeItem("authUser");
  };

  return (
    <AuthContext.Provider value={{ user, login, logout }}>
      {children}
    </AuthContext.Provider>
  );
}

export const useAuth = () => useContext(AuthContext);
Then wrap your app with <AuthProvider> as shown above.

5. How to use this in your FSAD‑PS41 project
Run:

bash
npx create-react-app fsad-ps41-frontend
cd fsad-ps41-frontend
Copy the folder structure and the above files under src/.

Later, uncomment axios.get("/api/workshops") and point to your backend (Node/Spring/Flask).
