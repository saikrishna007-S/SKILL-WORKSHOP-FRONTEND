2. Auth + role‑based navigation (React Router)
Install:

bash
npm install react-router-dom axios
Example App.jsx:

jsx
import { BrowserRouter as Router, Routes, Route } from "react-router-dom";
import { AuthProvider } from "./context/AuthContext";
import WorkshopManagement from "./pages/WorkshopManagement";
import UserDashboard from "./pages/UserDashboard";
import Login from "./pages/Login";

function App() {
  return (
    <AuthProvider>
      <Router>
        <Routes>
          <Route path="/" element={<Login />} />
          <Route path="/login" element={<Login />} />
          <Route path="/register" element={<Register />} />
          <Route path="/dashboard" element={<UserDashboard />} />
          <Route path="/admin/workshops" element={<WorkshopManagement />} />
          {/* ... other routes */}
        </Routes>
      </Router>
    </AuthProvider>
  );
}

export default App;
Use a PrivateRoute that checks role and redirect to /dashboard or /admin.

3. Sample React component: WorkshopCard
jsx
// components/WorkshopCard.jsx
import { Link } from "react-router-dom";

function WorkshopCard({ workshop, onRegister }) {
  return (
    <div className="border rounded-lg p-4 shadow hover:shadow-md transition">
      <h3 className="font-bold text-lg">{workshop.title}</h3>
      <p className="text-sm text-gray-600">
        {workshop.category} • {workshop.level}
      </p>
      <p className="text-sm">
        Starts: {new Date(workshop.startDate).toLocaleDateString()}
      </p>
      <button
        onClick={() => onRegister(workshop.id)}
        className="mt-2 bg-blue-600 text-white px-3 py-1 rounded text-sm"
      >
        {workshop.isRegistered ? "Registered" : "Register"}
      </button>
      <Link
        to={`/workshop/${workshop.id}`}
        className="block mt-1 text-blue-600 text-sm"
      >
        View Details
      </Link>
    </div>
  );
}

export default WorkshopCard;
